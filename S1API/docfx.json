{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "bin/MonoMelon/netstandard2.1",
          "files": [
            "S1API.dll"
          ]
        }
      ],
      "dest": "api",
      "namespaceLayout": "Nested",
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "shouldSkipMarkup": false,
      "force": true,
      "repo": {
        "remote": "https://github.com/ifBars/S1API.git",
        "branch": "stable",
        "path": "S1API"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern",
      "templates/material"
    ],
    "globalMetadata": {
      "_appName": "S1API",
      "_appTitle": "S1API Documentation",
      "_enableSearch": true,
      "_navbarTitle": "S1API",
      "pdf": true
    }
  }
}
